# Sao chép file này thành .env và điền giá trị thực

# SSH password để kết nối Synology NAS (dùng cho deploy.js, check_nas.js, v.v.)
NAS_SSH_PASSWORD=your_nas_ssh_password_here

# Mật khẩu admin mặc định khi bootstrap DB lần đầu (optional)
ADMIN_BOOTSTRAP_PASSWORD=

# Session secret (nếu cần)
SECRET_KEY=change_me_to_a_random_string
NODE_ENV=development
