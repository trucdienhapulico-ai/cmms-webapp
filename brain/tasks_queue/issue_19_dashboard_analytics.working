```javascript
// MTTR = Average time from WO creation to completion (in hours)
const doneWOs = db.workOrders.filter(w => w.status === 'done' && w.createdAt && w.updatedAt);
const mttr = doneWOs.length ? doneWOs.reduce((sum, w) => {
  return sum + (new Date(w.updatedAt) - new Date(w.createdAt)) / 3600000;
}, 0) / doneWOs.length : 0;

// MTBF = Mean Time Between Failures (days) - from maintenance logs with failures
const failLogs = (db.maintenanceLogs || []).filter(l => (l.results||[]).some(r => r.status === 'fail'));
// Calculate average days between consecutive failures
const mtbf = failLogs.length > 1 ? /* calc days between sorted fail dates */ : 0;

// PM Compliance = (PMs executed on time / Total active PMs) * 100
const activePMs = (db.pmSchedules||[]).filter(p => p.status === 'active');
const compliantPMs = activePMs.filter(p => p.generatedCount > 0);
const pmCompliance = activePMs.length ? (compliantPMs.length / activePMs.length * 100) : 100;

// Overdue Rate = (Overdue WOs / Total open WOs) * 100
