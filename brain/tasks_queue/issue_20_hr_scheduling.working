## Step-by-Step Instructions

### Step 1: Add DB schema in server.js

In `loadDB()` function, add:
```javascript
if (!db.shifts) { db.shifts = []; saveDB(db); }
```

In `initDB()` function, add `shifts: []` to the db object.

### Step 2: Create Shift API routes in server.js (before health check)

```javascript
// GET /api/shifts?from=YYYY-MM-DD&to=YYYY-MM-DD&userId=xxx
// Returns shifts filtered by date range and/or user
app.get('/api/shifts', requireAuth(), (req, res) => {
  const db = loadDB();
  const { from, to, userId } = req.query;
  let list = db.shifts || [];
  if (from) list = list.filter(s => s.date >= from);
  if (to) list = list.filter(s => s.date <= to);
  if (userId) list = list.filter(s => s.userId === userId);
  list = [...list].sort((a,b) => a.date.localeCompare(b.date));
  res.json({ ok: 1, data: list });
});

// POST /api/shifts - Create shift (admin/manager)
// Body: { userId, userName, date, shiftType, startTime, endTime, notes }
// shiftType: 'morning' | 'afternoon' | 'night'

// PUT /api/shifts/:id - Update shift

// DELETE /api/shifts/:id - Delete shift (admin)

// POST /api/shifts/:id/check-in - Operator checks in
// Set checkInAt = now(), status = 'checked-in'

// POST /api/shifts/:id/check-out - Operator checks out
// Set checkOutAt = now(), status = 'checked-out'

// GET /api/shifts/workload?month=YYYY-MM - Workload stats per user
// Return: [{ userId, userName, totalShifts, totalHours, activeWOs, completedWOs }]
// totalHours calculated from checkIn/checkOut or from shiftType defaults (8h each)
// activeWOs = WOs assigned to this user with status != done
// completedWOs = WOs assigned to this user with status = done
```

